@base <https://map.pardalotus.tech/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix f: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix s: <https://schema.org/> .
@prefix o: <https://www.w3.org/TR/owl-ref/#> .
@prefix k: <http://www.w3.org/2004/02/skos/core#> .


<Topic> f:label "Topic";.

<Entity> f:subClassOf <Topic>.
<Standard> f:subClassOf <Topic>;.
<Literature> f:subClassOf <Topic>;.
<ScholCommTopic> f:subClassOf <Topic>;  a <Intro>.
<Service> f:subClassOf <Topic>; a <Intro>.
<Individual> f:subClassOf <Entity>; a <Intro>.
<Organization> f:subClassOf <Entity>; a <Intro>.
<PublishingPlatform> f:subClassOf <Service>; f:label "Publishing Platform (manuscript tracking, peer review, etc)"; a <Intro>.
<ReadingPlatform> f:subClassOf <Service>; f:label "Reading, commenting, sharing platform"; a <Intro>.
<AbstractingAndIndexing> f:subClassOf <Service>; f:seeAlso <https://en.wikipedia.org/wiki/Indexing_and_abstracting_service> .

<Identifier> f:subClassOf <Topic>; a <Intro>.
<Blog> f:subClassOf <Literature>; a <Intro>.
<Newsletter> f:subClassOf <Literature>;.
<PodcastSeries> f:subClassOf <Literature>;.
<Tool> f:subClassOf <Topic>;;  a <Intro>.

<PodcastSeries> f:sameAs <s:PodcastSeries>.

<Society> f:subClassOf <Organization>;.
<Society> f:label "Society or Association".


<BuiltBy> a rdf:predicate; f:label "Built By";.
<MaintainedBy> a rdf:predicate; f:label "Maintained By";.
<AcquiredBy> a rdf:predicate; f:label "acquired by".

<Signatory> a rdf:predicate; f:label "Signatory".

<Homepage> a rdf:predicate; f:label "Homepage".
<BackgroundReading> a rdf:predicate; f:label "Background Reading".

<http://www.w3.org/2000/01/rdf-schema#seeAlso> f:label "see also".
<SourceCode> a rdf:predicate; f:label "Source Code".
<RelatedTo> a rdf:predicate; f:label "Related to";.
<SourceLicense> a rdf:predicate; f:label "Source License";.

<FF1000> <Parent> <TaylorAndFrancis>;.
<OpenSource> f:label "Open Source Code";.
<Proprietory> f:label "Proprietory Code";.


<Intro> f:label "Introductory Topic"; f:comment "Topics that are a good way into this map. These are unique or specific to scholarly infrastructure".

# ScholCommTopic


<Integrity>
    a <ScholCommTopic> ;
    f:label "Integrity" ;
    f:comment "Research integrity refers to all of the factors that underpin good research practice and promote trust and confidence in the research process - RIO";
    f:seeAlso <https://ukrio.org/research-integrity/what-is-research-integrity/>
.

<SingaporeStatement>
  f:label "Singapore Statement on Research Integrity";
  <About> <Integrity>;
  <Homepage> <https://www.wcrif.org/statement>.



<JournalTransfers> a <ScholCommTopic>; f:label "Journal Transfers"; f:comment "Transfer of journal between publishers. Often happens around the start of the year. Can mean big changes in metadata.";.
<CoAccess> a <ScholCommTopic>;.
<MultipleResolution> a <ScholCommTopic>;.
<Afiliation> a <ScholCommTopic>; f:comment "Afiliation of an author, i.e. which instutition they're working for. Authors can change afiliations, so this can be recorded against the Work at the time of publication".
<Content> a <ScholCommTopic>; f:comment "Scholarly Content (literature, datasets, video, etc)".
<Metadata> a <ScholCommTopic>; f:comment "Scholarly metadata. Information about content.".
<Contributor> a <ScholCommTopic>; f:comment "Contribution to research and publication (e.g. authorship)";.
<References> a <ScholCommTopic>; f:comment "References between scholarly works (aka citations)".





# Concepts
<Sleuth>
f:subclassOf <Individual>;
f:label "Research Integrity Sleuth";
<About> <Integrity>;
<BackgroundReading> <https://www.nature.com/articles/d41586-025-02163-z>;
<BackgroundReading> <https://retractionwatch.com/2018/06/17/meet-the-scientific-sleuths-ten-whove-had-an-impact-on-the-scientific-literature/>;
<BackgroundReading> <https://www.nature.com/articles/d41586-025-02163-z>;
.



<Defunct> f:label "Defunct Organization or Service";.

<DoiRegistrationAgency>
f:subClassOf <Organization>;
f:label "DOI Registration Agency";
s:seeAlso "https://www.doi.org/the-community/existing-registration-agencies/";
<RelatedTo> <DOI>
.

<JATS> f:label "Journal Article Tag Suite (JATS)";.
<JATS> f:seeAlso <https://jats4r.niso.org/>;
<RelatedTo> <Content>
.

